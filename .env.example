# Litera — exemplo de variáveis de ambiente
# Copie para .env (gitignored) e preencha com os valores reais.

# --- Banco de dados (MySQL) ---
DB_PASSWORD=changeme

# --- JWT (chave de assinatura — gere algo longo e aleatório em prod) ---
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Google Books API (opcional — usado para sincronizar livro destaque do perfil) ---
GOOGLE_BOOKS_API_KEY=

# --- URL pública do frontend (usado nos redirects do Stripe Checkout) ---
APP_FRONTEND_URL=http://localhost:5173
